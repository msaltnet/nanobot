{
  "version": 1,
  "jobs": [
    {
      "id": "msalt-news-briefing-morning",
      "name": "msalt-news-briefing-morning",
      "enabled": true,
      "schedule": {
        "kind": "cron",
        "expr": "0 7 * * *",
        "tz": "Asia/Seoul"
      },
      "payload": {
        "kind": "agent_turn",
        "message": "아침 경제 브리핑을 만들어서 보내줘. news-briefing 스킬 사용.",
        "deliver": true,
        "channel": "telegram",
        "to": "${TELEGRAM_USER_ID}"
      },
      "state": {},
      "createdAtMs": 0,
      "updatedAtMs": 0,
      "deleteAfterRun": false
    },
    {
      "id": "msalt-news-briefing-evening",
      "name": "msalt-news-briefing-evening",
      "enabled": true,
      "schedule": {
        "kind": "cron",
        "expr": "0 19 * * *",
        "tz": "Asia/Seoul"
      },
      "payload": {
        "kind": "agent_turn",
        "message": "저녁 경제 브리핑을 만들어서 보내줘. news-briefing 스킬 사용.",
        "deliver": true,
        "channel": "telegram",
        "to": "${TELEGRAM_USER_ID}"
      },
      "state": {},
      "createdAtMs": 0,
      "updatedAtMs": 0,
      "deleteAfterRun": false
    }
  ]
}
